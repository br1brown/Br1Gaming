# File .env locale (eventuali override/segreti). La configurazione del template
# vive in global-settings.json, non in un .env: questa riga è solo una rete di
# sicurezza per non committare per sbaglio un .env aggiunto a livello di progetto.
.env

# Override locale con i SEGRETI REALI di produzione (SecretKey, ApiKeys, ...).
# deploy.sh/public-test.sh lo fondono su global-settings.json; senza questo file lo
# stack parte comunque (br1-config.sh genera un ApiKey effimero), così il template gira
# subito ma i segreti veri restano fuori dal repo. Vedi global-settings.local.example.json.
global-settings.local.json
# File di config effettivo generato dal merge (montato nei container).
.br1-settings.effective.json
# Backup dei volumi dati prodotti da backup.sh
/backups/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
frontend/public/
# environment.ts è generato da generate-statics MA resta committato di proposito
# (non ignorato): il generatore importa site.ts → environment.ts, quindi serve un
# "seed" per farlo partire (chicken-and-egg). Si rigenera identico, niente rumore in git.
.claude
frontend/src/assets/files/image-cache
frontend/lh-report.json
frontend/ssr-server*.log
