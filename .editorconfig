# EditorConfig — formattazione coerente tra editor e collaboratori.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Config e manifest: 2 spazi (convenzione JSON/YAML)
[*.{json,jsonc,yml,yaml}]
indent_size = 2

# Markdown: i due spazi finali sono significativi (a capo forzato)
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# Makefile (se aggiunto in futuro): richiede tab reali
[Makefile]
indent_style = tab
