# Tutti i file testuali: LF nel repo E nel working tree, su ogni OS. Rende git
# coerente con .editorconfig (end_of_line = lf) invece di lasciar decidere alla
# config locale di ognuno. Elimina i diff spuri di fine-riga (es. un generatore
# che scrive LF su un checkout Windows a CRLF) e protegge lo shebang degli .sh
# nei container Linux.
* text=auto eol=lf

# Eccezione: la solution di Visual Studio segue la convenzione Windows (CRLF).
*.sln text eol=crlf

# File interamente del figlio: il merge dal template non li tocca mai.
# Il figlio li riscrive da zero ad ogni progetto.
frontend/src/assets/i18n/addon.*.json merge=ours
frontend/src/assets/mapping.json merge=ours
frontend/src/app/core/services/api.service.ts merge=ours
frontend/src/app/pages/home/home.component.ts merge=ours
frontend/src/app/pages/home/home.component.html merge=ours
frontend/src/styles.scss merge=ours
frontend/src/styles/app/** merge=ours

# Backend: file interamente del figlio.
backend/Controllers/BaseController.cs merge=ours

# Asset binari: nessun diff testuale, nessun problema di line ending.
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
